generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  category    String  
  amount      Decimal  @db.Decimal(10, 2)
  status      String   
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt]) // Essencial para o filtro de data ser performático
  @@map("transactions")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  entityId  Int
  action    String
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  createdAt DateTime @default(now())

  @@map("audit_logs")
}