{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["node_modules/@prisma/client"]
    }
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts", "swagger.json"],
  "exclude": ["node_modules", "dist"]
}